import java.util.ArrayList;
import java.util.Scanner;

public class Transaction {
    static class User {
        String id;
        int start;
        ArrayList<Integer> duration;

        public User(String id, int start) {
            this.id = id;
            this.start = start;
            duration = new ArrayList<>();
        }

        public static void main(String[] args) {
            Scanner sc = new Scanner(System.in);
            ArrayList<User> users = new ArrayList<>();
            System.out.print("Enter the number of users");
            int n = sc.nextInt();
            for (int i = 0; i < n; i++) {
                System.out.print("Enter ID: ");
                String id = sc.next();

                System.out.print("Enter Start Time: ");
                int start = sc.nextInt();

                System.out.print("Enter Number of Transactions: ");
                int t = sc.nextInt();

                User u = new User(id, start);

                System.out.print("Enter Durations: ");
                for(int j = 0; j < t; j++) {
                    u.duration.add(sc.nextInt());
                }
                users.add(u);
            }
            int totalWait = 0;
            int currentTime = 0;
            int totalTransaction = 0;
            for (User u : users) {
                currentTime = Math.max(currentTime, u.start);
                for (int i = 0; i < u.duration.size(); i++) {
                    int startTime = currentTime;
                    int transactionDuration = u.duration.get(i);
                    int endTime = startTime + transactionDuration;
                    int waitTime = startTime - u.start;
                    System.out.printf("User %s Transaction %d: Start time: %d End time: %d " +
                                    "Waiting time: %d - %d = %d seconds%n",
                            u.id, i + 1,
                            startTime, endTime,
                            startTime, u.start, waitTime);
                    totalTransaction++;
                    totalWait += waitTime;
                    currentTime = endTime;
                }
            }
            double avgWaitingTime = (double) totalWait / totalTransaction;
            System.out.printf("Average waiting time: %.2f seconds%n", avgWaitingTime);
        }
    }
}

import java.util.Random;

public class Factory {
    static Random r = new Random();
    static public double uniformRandom(int min, int max) {
        return min + r.nextDouble() * (max - min);
    }
    static public double normalRandom(int mean, int stddev) {
        double u1 = r.nextDouble();
        double u2 = r.nextDouble();
        //double z = Math.sqrt(-2.0 * Math.log(u1)) * Math.cos(2.0 * Math.PI * u2);
        return mean + stddev * r.nextGaussian();
    }
    static public double generatePolishingTime() {
        double t;
        do {
            t = normalRandom(20, 7);
        }while(t < 5);
        return t;
    }
    static public int argmin(double [] arr) {
        int idx = 0;
        for (int i = 1; i < arr.length; i++) {
            if(arr[i] < arr[idx]) idx = i;
        }
        return idx;
    }
    static public double simulate(int noOfMachines, int T){
        double[] worker = new double[10];
        double[] machine = new double[noOfMachines];
        double totalWait = 0.0;
        int items = 0;
        while(true) {
            int w = argmin(worker);
            double workerStart = worker[w];
            if(workerStart >= T) break;
            double assemblyTime = uniformRandom(100, 200);
            double polishTime = generatePolishingTime();
            double assemblyDone = workerStart + assemblyTime;
            int k = argmin(machine);
            double machineStart = Math.max(machine[k], assemblyDone);
            double wait = machineStart - assemblyDone;
            items++;
            totalWait += wait;
            machine[k] = machineStart + polishTime;
            worker[w] = machine[k];
        }
        return (items == 0)? 0.0 :(totalWait/items);
    }

    public static void main(String[] args) {
        int T = 8*60*60;
        for (int i = 1; i <= 3; i++) {
            System.out.println("Machines : " + i + " | Avg Wait : " +  simulate(i, T));
        }
    }
}
